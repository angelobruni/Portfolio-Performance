## 9. Value-at-Risk & CVaR — BL Optimal Portfolio
from scipy.stats import norm

PORTFOLIO_VALUE = 100_000
port_returns_daily = returns @ w_bl

print('=== Value-at-Risk Analysis — BL Max Sharpe Portfolio ===')
print(f'Portfolio Value: €{PORTFOLIO_VALUE:,}\n')

var_results = []
for cl in [0.95, 0.99]:
    alpha = 1 - cl
    
    # Parametric
    z = norm.ppf(alpha)
    var_param = -(port_returns_daily.mean() + z * port_returns_daily.std()) * PORTFOLIO_VALUE
    
    # Historical
    var_hist  = -np.percentile(port_returns_daily, alpha*100) * PORTFOLIO_VALUE
    
    # CVaR
    thr = np.percentile(port_returns_daily, alpha*100)
    cvar = -port_returns_daily[port_returns_daily <= thr].mean() * PORTFOLIO_VALUE
    
    var_results.append({
        'Confidence': f'{int(cl*100)}%',
        'Param VaR (€)':  round(var_param),
        'Hist VaR (€)':   round(var_hist),
        'CVaR (€)':       round(cvar)
    })
    print(f'{int(cl*100)}% | Parametric VaR: €{var_param:,.0f} | Historical VaR: €{var_hist:,.0f} | CVaR: €{cvar:,.0f}')

var_df = pd.DataFrame(var_results).set_index('Confidence')
