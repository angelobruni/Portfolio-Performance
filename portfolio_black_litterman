## 7. Step 4 — Portfolio Optimisation on BL Returns
def port_ret(w): return w @ mu_BL
def port_vol(w): return np.sqrt(w @ Sigma_np @ w)
def neg_sharpe_bl(w): return -(port_ret(w) - RF) / port_vol(w)

constraints = {'type': 'eq', 'fun': lambda w: np.sum(w) - 1}

# Long-only with max 25% per asset (diversification constraint)
bounds = tuple((0.0, 0.25) for _ in range(n))
w0 = np.array([1/n] * n)

# Max Sharpe on BL returns
res = minimize(neg_sharpe_bl, w0, method='SLSQP',
               bounds=bounds, constraints=constraints)
w_bl = res.x

# Min Variance
res_mv = minimize(port_vol, w0, method='SLSQP',
                  bounds=bounds, constraints=constraints,
                  args=())
w_mv = res_mv.x

# Equal weight benchmark
w_eq = w0.copy()

def summary(w, label):
    return pd.Series({
        'Return (%)':     round(port_ret(w)*100, 2),
        'Volatility (%)': round(port_vol(w)*100, 2),
        'Sharpe':         round((port_ret(w)-RF)/port_vol(w), 3)
    }, name=label)

result = pd.concat([
