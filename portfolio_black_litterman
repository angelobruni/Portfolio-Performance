## 10. View Sensitivity Analysis
How sensitive is the optimal allocation to changes in individual view confidence?
tau_range = np.linspace(0.01, 0.25, 20)
sensitivity = []

for t in tau_range:
    Om_t = np.diag([t * (P[i] @ Sigma_np @ P[i]) for i in range(k)])
    tSig_inv = np.linalg.inv(t * Sigma_np)
    Om_inv_t = np.linalg.inv(Om_t)
    mu_t = np.linalg.inv(tSig_inv + P.T @ Om_inv_t @ P) @ (tSig_inv @ Pi + P.T @ Om_inv_t @ Q)
    sensitivity.append(mu_t * 100)

sens_df = pd.DataFrame(sensitivity, columns=asset_names, index=tau_range)

fig, ax = plt.subplots(figsize=(12, 6))
for col in sens_df.columns:
    ax.plot(tau_range, sens_df[col], label=col, linewidth=2)

ax.axvline(0.075, color='white', linestyle=':', linewidth=1.5, label='Base tau=0.075')
ax.set_xlabel('Tau (uncertainty in prior)', fontsize=11)
ax.set_ylabel('BL Expected Return (%)', fontsize=11)
ax.set_title('Sensitivity of BL Returns to Prior Uncertainty (tau)', fontsize=13, fontweight='bold')
ax.legend(loc='upper right', fontsize=8, ncol=2)
