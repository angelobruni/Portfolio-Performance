## 8. Efficient Frontier — BL vs Historical Markowitz
N_SIM = 8000
np.random.seed(42)

sim_vols_bl, sim_rets_bl, sim_sr_bl = [], [], []
sim_vols_mk, sim_rets_mk, sim_sr_mk = [], [], []

for _ in range(N_SIM):
    w = np.random.dirichlet(np.ones(n))
    
    # BL
    r_bl  = w @ mu_BL
    v_bl  = np.sqrt(w @ Sigma_np @ w)
    sim_rets_bl.append(r_bl)
    sim_vols_bl.append(v_bl)
    sim_sr_bl.append((r_bl - RF) / v_bl)
    
